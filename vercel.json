
{
  "functions": {
    "api/analyze.js":    { "includeFiles": "node_modules/@google/genai/**" },
    "api/education.js":  { "includeFiles": "node_modules/@google/genai/**" },
    "api/revalidate.js": { "includeFiles": "node_modules/@google/genai/**" }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
